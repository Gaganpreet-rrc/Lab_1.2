generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id        Int        @id @default(autoincrement())
  name      String
  employees Employee[]
}

model Employee {
  id     Int    @id @default(autoincrement())
  name   String
  email  String @unique
  roleId Int
  role   Role   @relation(fields: [roleId], references: [id])
}
